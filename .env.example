# TestCollab MCP Server Configuration

# Base URL for TestCollab API
# Default: http://localhost:1337
TC_API_URL=http://localhost:1337

# API Token for authentication (required)
# Get this from your TestCollab user profile -> API Tokens
TC_API_TOKEN=your-api-token-here

# Project context cache TTL in milliseconds
# Default: 300000 (5 minutes). Set to 0 to disable caching.
TC_PROJECT_CONTEXT_CACHE_TTL_MS=300000
